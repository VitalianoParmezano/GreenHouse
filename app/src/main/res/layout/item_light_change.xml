<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <SeekBar
        android:id="@+id/item_blue_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:splitTrack="false"
        android:indeterminate="false"
        android:thumb="@drawable/thumb"
        android:progressDrawable="@drawable/track"
        android:thumbOffset="0dp"


        android:layout_marginTop="5dp"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="60dp"

        app:layout_constraintEnd_toStartOf="@id/item_lamp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/item_tv_blue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 %"
        android:textSize="16sp"
        android:textColor="@color/text_color"
        app:layout_constraintTop_toTopOf="@id/item_blue_seekbar"
        app:layout_constraintBottom_toBottomOf="@id/item_blue_seekbar"
        app:layout_constraintEnd_toEndOf="@id/item_tv_red"
        app:layout_constraintStart_toStartOf="@id/item_tv_red"
        />


    <SeekBar
        android:id="@+id/item_red_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:splitTrack="false"
        android:indeterminate="false"
        android:thumb="@drawable/thumb"
        android:progressDrawable="@drawable/track"
        android:thumbOffset="0dp"

        android:layout_marginStart="5dp"
        android:layout_marginEnd="60dp"

        android:progressTint="@color/soft_red"
        android:progressBackgroundTint="@color/soft_red"
        android:thumbTint="@color/red"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/item_blue_seekbar"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/item_tv_red"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 %"
        android:textSize="16sp"
        android:textColor="@color/text_color"
        app:layout_constraintTop_toTopOf="@id/item_red_seekbar"
        app:layout_constraintEnd_toEndOf="@id/item_red_seekbar"
        app:layout_constraintBottom_toBottomOf="@id/item_red_seekbar"
        app:layout_constraintStart_toStartOf="@id/item_red_seekbar"/>

    <View
        android:id="@+id/item_lamp"
        android:layout_width="@dimen/lamp_size"
        android:layout_height="@dimen/lamp_size"
        android:background="@drawable/shape_lamp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/item_red_seekbar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/item_tv_lamp_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textSize="30sp"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="@id/item_lamp"
        app:layout_constraintEnd_toEndOf="@id/item_lamp"
        app:layout_constraintStart_toStartOf="@id/item_lamp"
        app:layout_constraintBottom_toBottomOf="@id/item_lamp"/>

</androidx.constraintlayout.widget.ConstraintLayout>