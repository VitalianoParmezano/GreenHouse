<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="500dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/dialogView_header_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Встановити відсоток"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"

        />


    <TextView
        android:id="@+id/dialogView_redColor_input_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:text="Червоний колір"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/dialogView_header_tv"
        app:layout_constraintStart_toStartOf="parent"/>

    <EditText
        android:id="@+id/dialog_redInput_et"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="2"
        android:inputType="numberDecimal"
        android:layout_marginStart="50dp"
        app:layout_constraintBottom_toBottomOf="@+id/dialogView_redColor_input_tv"
        app:layout_constraintStart_toEndOf="@id/dialogView_redColor_input_tv"
        app:layout_constraintTop_toTopOf="@id/dialogView_redColor_input_tv" />

    <TextView
        android:id="@+id/dialogView_blueColor_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:text="Синій колір"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/dialogView_redColor_input_tv"
        app:layout_constraintStart_toStartOf="parent"/>

    <EditText
        android:id="@+id/dialog_blueInput_et"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="2"
        android:inputType="numberDecimal"
        app:layout_constraintBottom_toBottomOf="@+id/dialogView_blueColor_tv"
        app:layout_constraintEnd_toEndOf="@+id/dialog_redInput_et"
        app:layout_constraintTop_toTopOf="@id/dialogView_blueColor_tv" />

    <View
        android:id="@+id/dialog_lamp"
        android:layout_width="@dimen/lamp_size"
        android:layout_height="@dimen/lamp_size"
        android:background="@drawable/shape_lamp"
        app:layout_constraintBottom_toBottomOf="@+id/dialog_blueInput_et"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/dialog_blueInput_et"
        app:layout_constraintTop_toTopOf="@+id/dialog_redInput_et" />

    <TextView
        android:id="@+id/item_tv_lamp_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textSize="30sp"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="@id/dialog_lamp"
        app:layout_constraintEnd_toEndOf="@id/dialog_lamp"
        app:layout_constraintStart_toStartOf="@id/dialog_lamp"
        app:layout_constraintBottom_toBottomOf="@id/dialog_lamp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>