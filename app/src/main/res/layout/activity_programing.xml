<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProgramingActivity">
    <Button
        android:id="@+id/btn_programming_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:text="Back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_shelf_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Стелаж № x"
        android:textColor="@color/text_color"
        android:textSize="30sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>


    <GridLayout
        android:id="@+id/grid_programing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="150dp"
        android:rowCount="4"
        android:columnCount="2"/>


    <!--        android:thumbTint="#f00"-->
    <!--        android:progressBackgroundTint="#0f0"-->
    <!--        android:progressTint="#FF7A7A"-->

</androidx.constraintlayout.widget.ConstraintLayout>